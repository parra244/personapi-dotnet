@model IEnumerable<personapi_dotnet.Models.Entities.Persona>
@{ ViewData["Title"] = "Personas"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-people"></i> Personas</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Nueva Persona
    </a>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Cédula</th>
                        <th>Nombre</th>
                        <th>Apellido</th>
                        <th>Género</th>
                        <th>Edad</th>
                        <th>Teléfonos</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model)
                    {
                        <tr>
                            <td>@p.Cc</td>
                            <td>@p.Nombre</td>
                            <td>@p.Apellido</td>
                            <td>
                                <span class="badge @(p.Genero == "M" ? "bg-primary" : "bg-danger")">
                                    @(p.Genero == "M" ? "Masculino" : "Femenino")
                                </span>
                            </td>
                            <td>@p.Edad</td>
                            <td>@p.Telefonos.Count</td>
                            <td>
                                <a asp-action="Details" asp-route-id="@p.Cc" class="btn btn-sm btn-info text-white">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a asp-action="Edit" asp-route-id="@p.Cc" class="btn btn-sm btn-warning">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@p.Cc" class="btn btn-sm btn-danger">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
