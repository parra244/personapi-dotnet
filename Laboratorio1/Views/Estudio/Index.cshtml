@model IEnumerable<personapi_dotnet.Models.Entities.Estudio>
@{ ViewData["Title"] = "Estudios"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-book"></i> Estudios</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Nuevo Estudio
    </a>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Profesión</th>
                        <th>Cédula Persona</th>
                        <th>Universidad</th>
                        <th>Fecha de Grado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@(item.Profesion?.Nom ?? item.IdProf.ToString())</td>
                            <td>@(item.Persona?.Nombre ?? item.CcPer.ToString())</td>
                            <td>@item.Univer</td>
                            <td>@(item.Fecha.HasValue ? item.Fecha.Value.ToShortDateString() : "")</td>
                            <td>
                                <a asp-action="Details" asp-route-idProf="@item.IdProf" asp-route-ccPer="@item.CcPer" class="btn btn-sm btn-info text-white">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a asp-action="Edit" asp-route-idProf="@item.IdProf" asp-route-ccPer="@item.CcPer" class="btn btn-sm btn-warning">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a asp-action="Delete" asp-route-idProf="@item.IdProf" asp-route-ccPer="@item.CcPer" class="btn btn-sm btn-danger">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
