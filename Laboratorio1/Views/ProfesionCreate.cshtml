@* ─── CREATE ─────────────────────────────────────────────────────────── *@
@* Save as Views/Profesion/Create.cshtml *@
@model personapi_dotnet.Models.Entities.Profesion
@{ ViewData["Title"] = "Nueva Profesión"; }
<div class="d-flex align-items-center mb-3 gap-2">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i></a>
    <h2 class="mb-0"><i class="bi bi-briefcase"></i> Nueva Profesión</h2>
</div>
<div class="card" style="max-width:600px">
    <div class="card-body">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
            <div class="mb-3">
                <label asp-for="Id" class="form-label fw-semibold"></label>
                <input asp-for="Id" class="form-control" type="number" />
                <span asp-validation-for="Id" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Nom" class="form-label fw-semibold"></label>
                <input asp-for="Nom" class="form-control" />
                <span asp-validation-for="Nom" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Des" class="form-label fw-semibold"></label>
                <textarea asp-for="Des" class="form-control" rows="3"></textarea>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary"><i class="bi bi-save"></i> Guardar</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>
