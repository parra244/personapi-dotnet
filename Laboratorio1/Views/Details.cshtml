@model personapi_dotnet.Models.Entities.Persona
@{ ViewData["Title"] = "Detalle Persona"; }

<div class="d-flex align-items-center mb-3 gap-2">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i></a>
    <h2 class="mb-0"><i class="bi bi-person"></i> @Model.Nombre @Model.Apellido</h2>
</div>

<div class="row g-3">
    <div class="col-md-5">
        <div class="card">
            <div class="card-header fw-semibold bg-primary text-white">Datos Personales</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">Cédula</dt>     <dd class="col-sm-8">@Model.Cc</dd>
                    <dt class="col-sm-4">Nombre</dt>     <dd class="col-sm-8">@Model.Nombre</dd>
                    <dt class="col-sm-4">Apellido</dt>   <dd class="col-sm-8">@Model.Apellido</dd>
                    <dt class="col-sm-4">Género</dt>     <dd class="col-sm-8">@(Model.Genero == "M" ? "Masculino" : "Femenino")</dd>
                    <dt class="col-sm-4">Edad</dt>       <dd class="col-sm-8">@Model.Edad años</dd>
                </dl>
            </div>
        </div>
    </div>

    <div class="col-md-7">
        <div class="card mb-3">
            <div class="card-header fw-semibold">Teléfonos</div>
            <div class="card-body p-0">
                <table class="table mb-0">
                    <thead><tr><th>Número</th><th>Operador</th></tr></thead>
                    <tbody>
                        @foreach (var t in Model.Telefonos)
                        {
                            <tr><td>@t.Num</td><td>@t.Oper</td></tr>
                        }
                        @if (!Model.Telefonos.Any())
                        {
                            <tr><td colspan="2" class="text-muted text-center">Sin teléfonos registrados</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card">
            <div class="card-header fw-semibold">Estudios</div>
            <div class="card-body p-0">
                <table class="table mb-0">
                    <thead><tr><th>Profesión</th><th>Universidad</th><th>Fecha</th></tr></thead>
                    <tbody>
                        @foreach (var e in Model.Estudios)
                        {
                            <tr>
                                <td>@e.Profesion?.Nom</td>
                                <td>@e.Univer</td>
                                <td>@e.Fecha?.ToString("dd/MM/yyyy")</td>
                            </tr>
                        }
                        @if (!Model.Estudios.Any())
                        {
                            <tr><td colspan="3" class="text-muted text-center">Sin estudios registrados</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="mt-3 d-flex gap-2">
    <a asp-action="Edit" asp-route-id="@Model.Cc" class="btn btn-warning">
        <i class="bi bi-pencil"></i> Editar
    </a>
    <a asp-action="Index" class="btn btn-outline-secondary">Volver</a>
</div>
