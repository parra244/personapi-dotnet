@model personapi_dotnet.Models.Entities.Persona
@{ ViewData["Title"] = "Nueva Persona"; }

<div class="d-flex align-items-center mb-3 gap-2">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i></a>
    <h2 class="mb-0"><i class="bi bi-person-plus"></i> Nueva Persona</h2>
</div>

<div class="card" style="max-width:600px">
    <div class="card-body">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="mb-3">
                <label asp-for="Cc" class="form-label fw-semibold"></label>
                <input asp-for="Cc" class="form-control" placeholder="Número de cédula" />
                <span asp-validation-for="Cc" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Nombre" class="form-label fw-semibold"></label>
                <input asp-for="Nombre" class="form-control" />
                <span asp-validation-for="Nombre" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Apellido" class="form-label fw-semibold"></label>
                <input asp-for="Apellido" class="form-control" />
                <span asp-validation-for="Apellido" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Genero" class="form-label fw-semibold"></label>
                <select asp-for="Genero" class="form-select">
                    <option value="">-- Seleccione --</option>
                    <option value="M">Masculino</option>
                    <option value="F">Femenino</option>
                </select>
                <span asp-validation-for="Genero" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Edad" class="form-label fw-semibold"></label>
                <input asp-for="Edad" class="form-control" type="number" min="0" max="150" />
                <span asp-validation-for="Edad" class="text-danger small"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-save"></i> Guardar
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>
