<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PersonaAPI</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <style>
        .sidebar { min-height: 100vh; background: #1e3a5f; }
        .sidebar .nav-link { color: #cfe2ff; }
        .sidebar .nav-link:hover, .sidebar .nav-link.active { color: #fff; background: rgba(255,255,255,.15); border-radius: 6px; }
        .sidebar .brand { color: #fff; font-weight: 700; font-size: 1.2rem; }
        body { background: #f4f7fb; }
        .card { border: none; box-shadow: 0 2px 8px rgba(0,0,0,.08); }
        .table th { background: #1e3a5f; color: #fff; }
    </style>
</head>
<body>
<div class="container-fluid">
    <div class="row">
        <!-- Sidebar -->
        <nav class="col-md-2 d-none d-md-block sidebar py-3 px-2">
            <div class="brand mb-4 ps-2">
                <i class="bi bi-person-badge"></i> PersonaAPI
            </div>
            <ul class="nav flex-column gap-1">
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")"
                       asp-controller="Home" asp-action="Index">
                        <i class="bi bi-house"></i> Inicio
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Persona" ? "active" : "")"
                       asp-controller="Persona" asp-action="Index">
                        <i class="bi bi-people"></i> Personas
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Profesion" ? "active" : "")"
                       asp-controller="Profesion" asp-action="Index">
                        <i class="bi bi-briefcase"></i> Profesiones
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Estudio" ? "active" : "")"
                       asp-controller="Estudio" asp-action="Index">
                        <i class="bi bi-mortarboard"></i> Estudios
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Telefono" ? "active" : "")"
                       asp-controller="Telefono" asp-action="Index">
                        <i class="bi bi-telephone"></i> Teléfonos
                    </a>
                </li>
                <li class="nav-item mt-3">
                    <a class="nav-link" href="/swagger" target="_blank">
                        <i class="bi bi-code-slash"></i> Swagger API
                    </a>
                </li>
            </ul>
        </nav>

        <!-- Main content -->
        <main class="col-md-10 ms-sm-auto px-4 py-4">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle"></i> @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @RenderBody()
        </main>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
