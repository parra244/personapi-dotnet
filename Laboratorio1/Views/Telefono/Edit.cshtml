@model personapi_dotnet.Models.Entities.Telefono
@{ ViewData["Title"] = "Editar Teléfono"; }

<h2>Editar Teléfono</h2>
<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Num" />
            
            <div class="mb-3">
                <label class="form-label">Número</label>
                <input class="form-control" value="@Model.Num" disabled />
            </div>
            
            <div class="mb-3">
                <label asp-for="Oper" class="form-label"></label>
                <input asp-for="Oper" class="form-control" />
                <span asp-validation-for="Oper" class="text-danger"></span>
            </div>
            
            <div class="mb-3">
                <label asp-for="Duenio" class="form-label"></label>
                <select asp-for="Duenio" class="form-select" asp-items="ViewBag.Personas"></select>
                <span asp-validation-for="Duenio" class="text-danger"></span>
            </div>
            
            <div class="mb-3">
                <button type="submit" class="btn btn-warning">Guardar Cambios</button>
                <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
