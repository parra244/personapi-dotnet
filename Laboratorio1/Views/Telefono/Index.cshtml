@model IEnumerable<personapi_dotnet.Models.Entities.Telefono>
@{ ViewData["Title"] = "Teléfonos"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-telephone"></i> Teléfonos</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Nuevo Teléfono
    </a>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Número</th>
                        <th>Operador</th>
                        <th>Dueño (Cédula)</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Num</td>
                            <td>@item.Oper</td>
                            <td>@(item.Persona?.Nombre ?? item.Duenio.ToString())</td>
                            <td>
                                <a asp-action="Details" asp-route-id="@item.Num" class="btn btn-sm btn-info text-white">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a asp-action="Edit" asp-route-id="@item.Num" class="btn btn-sm btn-warning">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.Num" class="btn btn-sm btn-danger">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
